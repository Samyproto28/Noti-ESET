# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT Configuration - GENERATE YOUR OWN SECURE KEY!
JWT_SECRET=your_jwt_secret_at_least_32_characters_long

# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration (if using local PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/noti_eset

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_at_least_32_characters_long

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100